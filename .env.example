LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-v3.2

# Cost tracking (0 = disabled)
LLM_BUDGET_LIMIT_USD=0

# Test execution mode: "docker" (default, uses container) or "local" (in-process venv)
# TEST_EXECUTION_MODE=docker

# Skip virtual environment creation and run pytest with the system Python directly.
# Useful when venv creation fails on the host (broken Python install, permission
# issues, etc.). Set to 1 to enable.
# TEST_USE_SYSTEM_PYTHON=0

# Backend port for the web API (default 8000)
# WEB_PORT=8000